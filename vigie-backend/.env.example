# ==== Général ====
# Dev/mock : SQLite. Prod : chaîne Postgres de Supabase
#   (Supabase -> Project Settings -> Database -> Connection string / URI)
DATABASE_URL=sqlite:///./vigie.db
# DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@HOST.supabase.co:5432/postgres

# ==== Couche de données ====
# Lovable Cloud n'expose PAS la connexion Postgres directe -> on écrit via l'API Supabase.
# USE_SUPABASE=false -> SqlRepo (SQLite local, dev/mock)
# USE_SUPABASE=true  -> SupabaseRepo : écrit dans la MÊME base que le frontend
USE_SUPABASE=false
SUPABASE_URL=https://VOTRE_PROJET.supabase.co

# Clé "anon"/"publishable" -- PAS un secret, visible dans le code du frontend.
# (Lovable ne connait pas la vraie service role key, donc on ne l'utilise pas.)
SUPABASE_ANON_KEY=


# Compte de service Supabase Auth (role='admin' cote user_roles), cree une fois
# depuis Lovable. Le backend se connecte avec ces identifiants -- comme un
# utilisateur normal -- et passe par les policies RLS deja en place pour le role admin.
SUPABASE_SERVICE_EMAIL=moteur@vigie.internal
SUPABASE_SERVICE_PASSWORD=

# Conserve seulement si un jour tu as une vraie service role key (ex. projet
# Supabase autogere hors Lovable). Sinon laisser vide -- non utilise.
SUPABASE_SERVICE_ROLE_KEY=
ENGINE_AUTOSTART=true          # le moteur d'escalade tourne en tâche de fond
ENGINE_TICK_SECONDS=60

# ==== Sécurité / exploitation ====
# Clé OBLIGATOIRE pour les routes internes FastAPI (/api/dossiers, /api/calls,
# /api/settings, /api/kpi, /api/engine et webhook résultat du worker).
# Génération : python -c "import secrets; print(secrets.token_urlsafe(48))"
# Clients : en-tête X-API-Key: <clé> ou Authorization: Bearer <clé>.
# Le backend ET le worker agent doivent avoir exactement la même valeur.
VIGIE_API_KEY=

# Protège POST /api/engine/tick (obligatoire si un cron externe l'appelle).
# Génère une longue chaîne aléatoire.
ENGINE_TICK_TOKEN=

# CORS : "*" en dev. En prod, mets le domaine du frontend :
#   CORS_ORIGINS=https://ton-app.lovable.app
CORS_ORIGINS=*



# ==== Mode MOCK (tests sans VoIP ni OpenAI) ====
MOCK_MODE=true                  # true = appels simulés instantanément
MOCK_ANSWER_RATE=0.7           # probabilité que le constateur "décroche" en mock

# ==== Téléphonie (à régler quand ton VoIP est prêt) ====
# LiveKit Cloud (couche média) — https://cloud.livekit.io
# DEPUIS LOVABLE : ces 3 valeurs se règlent EN DIRECT depuis le dashboard ->
# Paramètres -> "Agent vocal & LiveKit" (table settings), sans redéploiement,
# pour tout ce que le BACKEND fait (dispatch d'un appel). Elles ne servent
# ici que de repli, ET restent nécessaires telles quelles dans le .env DU
# WORKER AGENT lui-même (agent/worker.py) pour son propre enregistrement
# auprès de LiveKit au démarrage — les changer en base ne reconnecte pas
# le worker à un autre projet sans redémarrage de ce processus.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# SIP_TRUNK_ID / SIP_CALLER_ID : DEPUIS LOVABLE, ces deux valeurs se règlent
# EN DIRECT depuis le dashboard -> Paramètres -> "Téléphonie IA (SIP)"
# (table settings.sip_trunk_id / sip_caller_id), sans redéploiement.
# Les variables ci-dessous ne servent plus que de REPLI si jamais aucune
# valeur n'a encore été enregistrée en base (utile pour un test local rapide
# sans passer par le dashboard).
SIP_TRUNK_ID=
SIP_CALLER_ID=
# Estimation uniquement : renseigner le tarif contractuel réel de l'opérateur.
# 0 signifie « non renseigné », pas « gratuit ».
SIP_ESTIMATED_COST_PER_MINUTE_USD=0

# ==== WhatsApp Business Calling via LiveKit Connector (chantier 3) ====
# Laisser false tant que Meta n'a pas activé les appels sortants et que les
# constateurs n'ont pas accordé leur permission explicite d'appel.
WHATSAPP_CALLS_ENABLED=false
# Token Cloud API META dédié aux appels — jamais une clé de l'application m2s-api.
WHATSAPP_CALLS_ACCESS_TOKEN=
# ID du numéro WhatsApp Business appelant dans WhatsApp Manager.
WHATSAPP_CALLS_PHONE_NUMBER_ID=
WHATSAPP_CALLS_CLOUD_API_VERSION=24.0
WHATSAPP_CALLS_DESTINATION_COUNTRY=MA
WHATSAPP_CALLS_RINGING_TIMEOUT_SECONDS=35
# Mettre ici le coût/min communiqué dans votre contrat Meta/LiveKit. 0 signifie
# « non renseigné », pas « appel garanti gratuit ».
WHATSAPP_ESTIMATED_COST_PER_MINUTE_USD=0

# ==== Agent vocal (Realtime ou pipeline STT -> LLM -> TTS) ====
# DEPUIS LOVABLE : réglable en direct -> Paramètres -> "Agent vocal & LiveKit"
# (settings.openai_api_key), transmis PAR APPEL à l'agent (aucun redémarrage
# nécessaire, contrairement à LIVEKIT_URL/KEY/SECRET ci-dessus). Repli env
# si non renseigné en base.
OPENAI_API_KEY=

# Replis utilisés en mode Playground ou avant la migration settings. En usage
# normal, ces valeurs sont pilotées en direct depuis /parametres et transmises
# au worker dans les métadonnées de chaque job.
VOICE_ENGINE=realtime
OPENAI_REALTIME_MODEL=gpt-realtime
STT_PROVIDER=openai
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_INPUT_LANGUAGE=ar
OPENAI_LLM_MODEL=gpt-4o-mini
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash

# ==== Agent — garde-fous de coût (voir agent/README.md) ====
# DEPUIS LOVABLE : les 4 valeurs ci-dessous (settings.vigie_api_base_url,
# agent_max_call_seconds, agent_max_response_tokens, agent_max_turns) sont
# réglables en direct -> Paramètres -> "Agent vocal & LiveKit", transmises
# PAR APPEL à l'agent. Repli sur ces variables env si non renseignées en base.
VIGIE_API_BASE_URL=http://127.0.0.1:8000
AGENT_MAX_CALL_SECONDS=60
AGENT_MAX_RESPONSE_TOKENS=200
AGENT_MAX_TURNS=6

# ==== WhatsApp Business Cloud API (notification hand-off) ====
# Le TOKEN, le PHONE_NUMBER_ID et le NUMÉRO destinataire se règlent DÉSORMAIS
# depuis Paramètres -> "SLA & escalade" -> menu déroulant de contacts
# (table whatsapp_contacts + settings.selected_whatsapp_id), gérés à la volée
# depuis le dashboard (ajout/suppression de contacts, sans redéploiement).
# WHATSAPP_TOKEN / WHATSAPP_PHONE_NUMBER_ID / ZINEB_WHATSAPP ci-dessous ne
# servent plus que de REPLI si aucun contact n'est encore sélectionné en base.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Template Meta approuvé (voir app/providers/whatsapp.py pour le texte exact
# à soumettre côté WhatsApp Manager avant que l'envoi réel fonctionne).
WHATSAPP_TEMPLATE_NAME=vigie_handoff_humain
WHATSAPP_TEMPLATE_LANG=fr
# Chaine secrete choisie par toi (ex. python -c "import secrets;print(secrets.token_urlsafe(24))")
# -- a recopier dans le champ "Verify token" du webhook cote Meta.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret Meta (App Dashboard -> Paramètres de l'app -> Général).
# Sert à vérifier X-Hub-Signature-256 sur chaque webhook POST reçu.
WHATSAPP_APP_SECRET=
ZINEB_WHATSAPP=+212XXXXXXXXX

# ==== Alertes texte via la plateforme m2s-api ====
# URL de base de l'API, par exemple https://api.m2s.ma/api/v1
M2S_WHATSAPP_API_URL=
# Clé API Bearer créée dans m2s-api avec le droit d'envoyer des messages.
M2S_WHATSAPP_API_KEY=
# Identifiant de l'instance WhatsApp expéditrice dans m2s-api.
M2S_WHATSAPP_INSTANCE_ID=

# ==== Synchronisation dossiers / statuts M2S (chantier 2) ====
# Le mode, l'URL de polling et la cadence se règlent depuis /parametres.
# Les secrets ci-dessous restent exclusivement côté backend.
# Jeton utilisé par le backend quand il interroge l'API M2S (mode polling).
M2S_API_TOKEN=
# Secret partagé avec M2S pour vérifier sha256=<HMAC du corps brut> sur
# POST /api/webhooks/m2s/dossier-status.
M2S_WEBHOOK_SECRET=

# TODO(M2S-CONTRACT) — ne pas inventer ces valeurs : les demander à M2S.
# Nom exact du champ dans le JSON. La notation pointée est acceptée (ex. dossier.statut).
M2S_STATUS_FIELD=
# Valeurs séparées par des virgules, comparées sans casse ni accents.
M2S_VALIDATED_STATUS_VALUES=
M2S_ACTIVE_STATUS_VALUES=

# Replis pour une installation n'ayant pas encore exécuté la migration settings.
M2S_DOSSIERS_API_URL=
M2S_POLL_ENABLED=false
M2S_POLL_INTERVAL_SECONDS=300

# ==== Générateur automatique de dossiers (en attendant l'API M2S) ====
# Cree un dossier FRAIS (SLA complet devant lui) toutes les N heures, pour un
# unique constateur. Remplace l'API M2S en attendant qu'elle soit disponible.
# Mettre a false le jour ou l'API M2S est branchee.
AUTO_DOSSIER_ENABLED=false
AUTO_DOSSIER_INTERVAL_HOURS=2
AUTO_DOSSIER_CONSTATEUR_TEL=+212600000000
AUTO_DOSSIER_CONSTATEUR_NOM=Constateur M2S
AUTO_DOSSIER_CONSTATEUR_ZONE=Casablanca
AUTO_DOSSIER_REF_PREFIX=DOS-AUTO
